<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Father's photo as background -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_father"
        android:scaleType="centerCrop"
        android:contentDescription="خلفية"/>

    <!-- Dark overlay for readability -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"/>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center">

        <!-- App Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="محمد عبد العظيم"
            android:textSize="28sp"
            android:textColor="#FFD700"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="لذكر الله"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:layout_marginBottom="48dp"/>

        <!-- Card -->
        <androidx.cardview.widget.CardView
            xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardCornerRadius="16dp"
            card_view:cardBackgroundColor="#CC1a1a2e"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <!-- Interval Spinner -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="اختر الفترة الزمنية"
                    android:textColor="#FFD700"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"/>

                <Spinner
                    android:id="@+id/spinnerInterval"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/spinner_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginBottom="24dp"/>

                <!-- Enable Switch -->
                <Switch
                    android:id="@+id/switchEnable"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تفعيل الأذكار"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:layout_marginBottom="16dp"/>

                <!-- Status -->
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏸ الأذكار متوقفة"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Zekr list label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="الأذكار المبرمجة:"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🤲 الصلاة على النبي ﷺ\n📖 آية الأحزاب\n🌟 الحمد لله\n🌟 استغفر الله\n🌟 لا حول ولا قوة إلا بالله\n🌟 سبحان الله\n🤍 ربي اغفر لي ولوالدي"
            android:textColor="#DDDDDD"
            android:textSize="13sp"
            android:lineSpacingExtra="6dp"
            android:gravity="center"/>

    </LinearLayout>
</RelativeLayout>
